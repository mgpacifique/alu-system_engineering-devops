#!/usr/bin/env bash
# Configures Nginx with a custom HTTP response header X-Served-By set to the server hostname

# Update and install Nginx
sudo apt-get update -y
sudo apt-get install -y nginx

# Get the hostname
HOSTNAME=$(hostname)

# Add custom header to the default server block (more reliable than conf.d)
sudo sed -i "/server_name _;/a\\\\tadd_header X-Served-By $HOSTNAME;" /etc/nginx/sites-available/default

# Ensure Nginx is started and enabled
sudo nginx -t && sudo service nginx restart
