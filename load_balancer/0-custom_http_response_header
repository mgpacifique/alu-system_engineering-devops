#!/usr/bin/env bash
# Configures Nginx with a custom HTTP response header X-Served-By set to the server hostname

sudo apt-get update -y
sudo apt-get install -y nginx

# Add header directly into the http block in nginx.conf
sudo sed -i "s/http {/http {\n    add_header X-Served-By \"$(hostname)\";/" /etc/nginx/nginx.conf

sudo service nginx restart